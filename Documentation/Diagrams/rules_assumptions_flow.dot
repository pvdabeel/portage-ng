digraph rules_assumptions_bpmn {
  rankdir=TD;
  labelloc="t";
  label="portage-ng: rules/prover assumption flow (current implementation, BPMN-style)";
  fontsize=12;
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];

  subgraph cluster_test_harness {
    label="pipeline.pl : prove_with_fallback / prove_plan_with_fallback";
    color="#888888";
    t_start [shape=circle, label="start"];
    t_strict [shape=box, label="strict:\nprover:prove / pipeline:prove_plan"];
    t_strict_ok [shape=diamond, label="success?"];
    t_keyword [shape=box, label="prover:assuming(keyword_acceptance,\n  prove / prove_plan)"];
    t_keyword_ok [shape=diamond, label="success?"];
    t_blockers [shape=box, label="prover:assuming(blockers,\n  prove / prove_plan)"];
    t_blockers_ok [shape=diamond, label="success?"];
    t_unmask [shape=box, label="prover:assuming(unmask,\n  prove / prove_plan)"];
    t_unmask_ok [shape=diamond, label="success?"];
    t_keyword_unmask [shape=box, label="prover:assuming(keyword_acceptance,\n  prover:assuming(unmask, prove / prove_plan))"];
    t_done [shape=doublecircle, label="proven"];
  }

  subgraph cluster_blockers_conflicts {
    label="rules.pl : blocker + conflict assumption controls";
    color="#888888";

    b_start [shape=circle, label="start"];

    b_kind [shape=diamond, label="blocker strength?"];

    b_pkg_weak [shape=box, label="package_dependency(weak):\nassume blocker + emit\nmake_blocker_constraint"];
    b_pkg_strong [shape=diamond, label="package_dependency(strong):\nbracket USE?"];
    b_pkg_strong_uncond [shape=box, label="unconditional (U == []):\nconstraint(blocked_cn(C,N))"];
    b_pkg_strong_cond [shape=box, label="conditional (U \\= []):\nassume blocker (avoid over-approximation)"];

    b_grouped_weak [shape=box, label="grouped_package_dependency(weak):\ncandidate:grouped_blocker_specs → all assumed\n+ make_blocker_constraint"];
    b_grouped_strong [shape=box, label="grouped_package_dependency(strong):\ncandidate:grouped_blocker_specs_partition(...,\nEnforceSpecs, AssumeSpecs)"];

    b_assume_blockers [shape=diamond, label="rules:assume_blockers?"];
    b_strong_assume_all [shape=box, label="assume all strong blockers:\nassume Enforce + Assume"];
    b_strong_enforce [shape=box, label="strict strong blockers:\nconstraint(blocked_cn) for Enforce\n+ assume for Assume"];

    b_conflict [shape=diamond, label="rule(conflict(A,B),...)"];
    b_conflict_assume [shape=box, label="rules:assume_conflicts →\n[assumed(conflict(A,B))]"];
    b_conflict_fail [shape=box, label="strict conflict → fail"];

    b_anyof_guard [shape=diamond, label="any_of_config_dep_ok/2\n(USE-dep option unsatisfied?)"];
    b_anyof_assume [shape=box, label="rules:assume_conflicts →\nallow option"];
    b_anyof_fail [shape=box, label="strict → reject option (fail)"];
  }

  subgraph cluster_grouped_dep {
    label="rules.pl + candidate.pl + use.pl + dependency.pl :\nrule(grouped_package_dependency(no,C,N,PackageDeps):Action?{Context}, Conditions)";
    color="#888888";

    g_start [shape=circle, label="start"];

    g_augment [shape=box, label="augment_package_deps_with_self_rdepend\n(dependency.pl — install only: propagate\nself-RDEPEND version bounds into PackageDeps)"];

    g_split [shape=diamond, label="should_split_grouped_dep(PackageDeps)?"];
    g_split_emit [shape=box, label="emit one grouped dep per package_dependency/8\n(findall + sort)\n+ constraint(selected_cn_allow_multislot(C,N):{true})"];

    g_self_run [shape=diamond, label="Action == run AND self(C,N)?"];
    g_ok_self [shape=box, label="Conditions = []"];

    g_emptytree_core [shape=diamond, label="emptytree AND core_pkg(C,N)?"];
    g_ok_core [shape=box, label="Conditions = []"];

    g_keep_installed [shape=diamond, label="keep-installed fast path?\n(!emptytree, !deep, same-slot installed,\nversion+slot constraints satisfied,\nbuild_with_use satisfied,\nvirtual bypass for USE deps,\nand no --newuse mismatch)"];
    g_ok_installed [shape=box, label="Conditions = []"];

    g_slotreq [shape=box, label="SlotReq = merge_slot_restriction(...)"];

    g_sslock [shape=diamond, label="SlotReq == [any_same_slot]\nAND context has slot(C,N,Ss)?"];
    g_sslock_bind [shape=box, label="SsLock = canon_any_same_slot_meta(Ss)\n(:= slot lock binding)"];

    g_select [shape=box, label="candidate selection (candidate.pl):\n─────────────────\n1. explicit slot dep → accepted_keyword_candidate\n2. selected_cn_candidate_compatible\n   (slot+domain check, CandPreVerified=true)\n3. accepted_keyword_candidate\n   with lazy inline rejection check\n   (CandPreVerified=false)"];

    g_self_guard [shape=diamond, label="candidate == self entry?"];
    g_self_installed [shape=diamond, label="if self candidate:\n!emptytree AND installed(true)?"];

    g_version_guard [shape=diamond, label="CandPreVerified == true\nOR cache:ordered_entry version\n+ preference:version_match\n+ effective domain pass?"];

    g_reverse_dep [shape=diamond, label="candidate_reverse_deps_compatible\n_with_parent?\n(RDEPEND back-check)"];

    g_pdepend [shape=diamond, label="PDEPEND edge in grouped deps?"];
    g_ctx_drop [shape=box, label="MergedUse = [],\ndrop parent build_with_use\n+ assumption_reason for this dep"];

    g_use_guard [shape=diamond, label="candidate_satisfies_use_deps?\n(use.pl)"];
    g_use_slot [shape=box, label="process_build_with_use (use.pl)\n+ process_slot (candidate.pl)\n(query_search_slot_constraint)"];

    g_bwu_ed_check [shape=diamond, style=filled, fillcolor="#ffe0e0",
                     label="check_bwu_ed_conflict(C,N,Ctx):\nBWU from context vs\nmemo:candidate_bwu_(C,N)?\n(feature_unification:val_hook)"];
    g_bwu_ed_fail [shape=box, style=filled, fillcolor="#ffdddd",
                    label="E/D conflict detected:\nassert memo:requse_violation_\n(use_flag_conflict descriptor)\n→ fail"];

    g_action_path [shape=diamond, label="same-slot installed instance\nfor update path?\n(SlotInstalled == SlotChosen)"];

    g_action_update [shape=box, label="ActionGoal = Candidate:update?{UpdateCtx}\n─────────────────\nChooses first matching:\n• version change → replaces(InstalledEntry)\n• !avoid_reinstall, !virtual,\n  build_with_use unsatisfied\n  → rebuild_reason(build_with_use)\n• --newuse mismatch\n  → rebuild_reason(newuse)"];

    g_action_install [shape=box, label="DepAction = (run → install ; else Action)\nActionGoal = Candidate:DepAction?{NewerContext}"];

    g_emit [shape=box, label="emit constraints + goal:\ncn_domain + cn_domain_reason + selected_cn\n+ selected_cn_allow_multislot\n  (slot/any_* OR exactish-versioned\n   OR version-constrained deps)\n+ build/use constraints + ActionGoal"];

    g_sel_policy [shape=note, label="constraint_guard(selected_cn):\nstrict single concrete entry per (C,N) by default;\nwith selected_cn_allow_multislot(C,N):\n- one concrete entry per SLOT, or\n- per (slot,subslot) for same-slot multiversion cases\n\nVersion-constrained deps always get multi-slot\nallowance so that e.g. minitest-5.15.0-r1:5.15\nand minitest-5.27.0:5 can coexist when ruby's\nPDEPEND requires >=minitest-5.16.3"];

    g_deep_keep [shape=diamond, label="deep fallback keep-installed?\n(installed same-slot satisfies\nall version constraints)"];
    g_ok_deep [shape=box, label="Conditions = []"];

    g_requse_guard [shape=diamond, style=filled, fillcolor="#ffe0e0",
                     label="memo:requse_violation_(C,N,_)?\n(skip reprove when\nUSE conflict already recorded)"];

    g_learn_parent [shape=box, label="maybe_learn_parent_narrowing(C,N,...)\n(heuristic.pl)\n─────────────────\nParent introduced a dep that made\n(C,N) unsatisfiable: narrow parent.\nSkipped for PDEPEND and multislot misses."];

    g_reprove [shape=box, label="maybe_request_grouped_dep_reprove(...)\n(heuristic.pl)\n→ throw rules_reprove_cn_domain(...)"];

    g_reason_call [shape=box, label="call explanation:\nassumption_reason_for_grouped_dep\n(..., _Reason)\nfor classification"];

    g_slot_conflict_check [shape=diamond, style=filled, fillcolor="#e0e0ff",
                            label="find_dep_slot_conflict(C,N,Desc)?\n(check memo:slot_conflict_\nfor this pkg or its deps)"];

    g_requse_ctx [shape=diamond, style=filled, fillcolor="#ffe0e0",
                   label="memo:requse_violation_(C,N,ViolDesc)?\n(retract and add to context)"];

    g_assume [shape=box, label="fallback assumption:\nassumed(grouped_package_dependency\n  (C,N,PackageDeps):Action?{Ctx})\nCtx augmented with:\n• domain_reason(cn_domain(...))\n• required_use_violation(ViolDesc)\n• slot_conflict(SlotConflictDesc)"];
  }

  subgraph cluster_bwu_cross_dep {
    label="rules.pl : :install / :run BWU cross-dep REQUIRED_USE check";
    color="#888888";
    fontcolor="#555555";

    bwu_start [shape=circle, label=":install / :run\nrule body"];
    bwu_check [shape=box, style=filled, fillcolor="#ffe0e0",
               label="check_bwu_cross_dep(C,N,Repo://Entry,BWU)\n─────────────────\nMerge BWU with memo:candidate_bwu_(C,N):\n• first occurrence: assert candidate_bwu_\n• subsequent: val_hook merge + verify_required_use_with_bwu"];
    bwu_merge_ok [shape=diamond, label="val_hook merge\nsucceeds?"];
    bwu_requse_ok [shape=diamond, label="verify_required_use\n_with_bwu passes?"];
    bwu_update [shape=box, label="update memo:candidate_bwu_\nwith merged BWU → continue"];
    bwu_requse_viol [shape=box, style=filled, fillcolor="#ffdddd",
                     label="describe_required_use_violation\n→ assert memo:requse_violation_\n→ fail"];
    bwu_ed_viol [shape=box, style=filled, fillcolor="#ffdddd",
                 label="compute_ed_conflict_desc\n→ assert memo:requse_violation_\n(use_flag_conflict)\n→ fail"];
  }

  subgraph cluster_cn_domain_conflict {
    label="rules.pl : constraint_unify_hook(cn_domain) — slot conflict detection";
    color="#888888";
    fontcolor="#555555";

    cd_start [shape=circle, label="cn_domain\nunify hook"];
    cd_has_existing [shape=diamond, label="cn_domain(C,N)\nalready in constraints?"];
    cd_put_new [shape=box, label="put_assoc(cn_domain(C,N),\nDomainDelta)"];
    cd_meet [shape=diamond, style=filled, fillcolor="#e0e0ff",
             label="version_domain:domain_meet\n(CurrentDomain, DomainDelta,\nMergedDomain) succeeds?"];
    cd_meet_ok [shape=box, label="put_assoc(cn_domain(C,N),\nMergedDomain)"];
    cd_meet_fail [shape=box, style=filled, fillcolor="#ffdddd",
                  label="domain_meet FAILED:\nassert memo:slot_conflict_(C,N,\n  domain_conflict(Current,Delta))\n→ fail"];
  }

  subgraph cluster_cn_reprove {
    label="heuristic.pl + prover.pl : CN-domain reprove retry loop";
    color="#888888";
    r_throw [shape=box, label="rules_reprove_cn_domain(C,N,Domain,Candidates,Reasons)\n(thrown from heuristic.pl)"];
    r_guard [shape=box, label="constraint_guard hooks that may throw reprove:\n- cn_domain + selected_cn compatibility\n- selected_cn uniqueness/domain partition\n- blocked_cn vs selected_cn source reprove"];
    r_catch [shape=box, label="prover:prove_with_cn_domain_retries/11 catches throw"];
    r_add [shape=box, label="candidate:add_cn_domain_rejects(...)\n(+ add_cn_domain_origin_rejects when Candidates=[])"];
    r_retry [shape=diamond, label="Attempt < MaxRetries\nAND any new reject added?"];
    r_recurse [shape=box, label="retry prove_once with updated reject map"];
    r_fallback [shape=box, label="exhausted/no-new-rejects:\nprove_once with cn-domain reprove disabled"];
    r_done [shape=doublecircle, label="final prove result"];
  }

  subgraph cluster_reason {
    label="explanation.pl : assumption_reason_for_grouped_dep/6 (called on grouped fallback)";
    color="#888888";
    e_start [shape=circle, label="start"];
    e_any [shape=diamond, label="Any package exists?\n(category+name)"];
    e_missing [shape=box, label="Reason = missing"];
    e_need_inst [shape=diamond, label="self-hosting requires\ninstalled-only?"];
    e_inst_empty [shape=diamond, label="installed-only set empty?"];
    e_inst_req [shape=box, label="Reason = installed_required"];
    e_unmasked1 [shape=diamond, label="Any unmasked candidates?"];
    e_masked [shape=box, label="Reason = masked"];
    e_slot_any [shape=diamond, label="slot restriction yields\nany candidates?"];
    e_slot_bad [shape=box, label="Reason = slot_unsatisfied"];
    e_unmasked2 [shape=diamond, label="Any unmasked slot candidates?"];
    e_versions [shape=diamond, label="version_constraint_analysis:\nany candidate satisfies all constraints?"];
    e_ver_nocand [shape=box, label="Reason = version_no_candidate(Op,Ver)"];
    e_ver_conflict [shape=box, label="Reason = version_conflict"];
    e_keywords [shape=diamond, label="any candidate matches\nACCEPT_KEYWORDS?"];
    e_kw [shape=box, label="Reason = keyword_filtered"];
    e_other [shape=box, label="Reason = unsatisfied_constraints"];
  }

  subgraph cluster_update_txn {
    label="target.pl : update action path (transactional, same-slot policy)";
    color="#888888";
    u_start [shape=circle, label="start"];
    u_has_replaces [shape=diamond, label="Context has replaces(...) ?"];
    u_txn [shape=box, label="target:update_txn_conditions(...)"];
    u_installed_target [shape=diamond, label="target is installed and newer\nacceptable same-slot version exists?"];
    u_delegate_latest [shape=box, label="delegate to Latest:update?{replaces(Target)}"];
    u_target_not_installed [shape=diamond, label="target not installed?"];
    u_same_slot_old [shape=diamond, label="same-slot installed old version exists?"];
    u_fallback_install [shape=box, label="fallback: Target:install?{Context}"];
    u_noop [shape=box, label="installed and no acceptable newer → []"];
    u_txn_detail [shape=box, label="target:update_txn_conditions does:\nrequired_use model + grouped install deps\n+ optional deep_update_goals (target.pl)\n+ use/slot constraints (+ download when needed)"];
  }

  // =========================================================================
  //  Edges: test harness
  // =========================================================================

  t_start -> t_strict;
  t_strict -> t_strict_ok;
  t_strict_ok -> t_done [label="yes"];
  t_strict_ok -> t_keyword [label="no"];
  t_keyword -> t_keyword_ok;
  t_keyword_ok -> t_done [label="yes"];
  t_keyword_ok -> t_blockers [label="no"];
  t_blockers -> t_blockers_ok;
  t_blockers_ok -> t_done [label="yes"];
  t_blockers_ok -> t_unmask [label="no"];
  t_unmask -> t_unmask_ok;
  t_unmask_ok -> t_done [label="yes"];
  t_unmask_ok -> t_keyword_unmask [label="no"];
  t_keyword_unmask -> t_done;

  // =========================================================================
  //  Edges: blocker + conflict handling
  // =========================================================================

  b_start -> b_kind;

  // Single package_dependency blocker rules
  b_kind -> b_pkg_weak [label="weak\n(package_dependency)"];
  b_kind -> b_pkg_strong [label="strong\n(package_dependency)"];
  b_pkg_strong -> b_pkg_strong_uncond [label="U == []"];
  b_pkg_strong -> b_pkg_strong_cond [label="U \\= []"];

  // Grouped package_dependency blocker rules
  b_kind -> b_grouped_weak [label="weak\n(grouped)"];
  b_kind -> b_grouped_strong [label="strong\n(grouped)"];
  b_grouped_strong -> b_assume_blockers;
  b_assume_blockers -> b_strong_assume_all [label="yes"];
  b_assume_blockers -> b_strong_enforce [label="no"];

  // Conflict + any_of
  b_conflict -> b_conflict_assume [label="assume_conflicts"];
  b_conflict -> b_conflict_fail [label="strict"];
  b_anyof_guard -> b_anyof_assume [label="yes + assume_conflicts"];
  b_anyof_guard -> b_anyof_fail [label="yes + strict"];

  // =========================================================================
  //  Edges: grouped dependency resolution (main flow)
  // =========================================================================

  g_start -> g_augment;
  g_augment -> g_split;
  g_split -> g_split_emit [label="yes"];
  g_split -> g_self_run [label="no"];
  g_self_run -> g_ok_self [label="yes"];
  g_self_run -> g_emptytree_core [label="no"];
  g_emptytree_core -> g_ok_core [label="yes"];
  g_emptytree_core -> g_keep_installed [label="no"];
  g_keep_installed -> g_ok_installed [label="yes"];
  g_keep_installed -> g_slotreq [label="no"];

  g_slotreq -> g_sslock;
  g_sslock -> g_sslock_bind [label="yes"];
  g_sslock -> g_select [label="no"];
  g_sslock_bind -> g_select;

  g_select -> g_self_guard;
  g_self_guard -> g_self_installed [label="yes"];
  g_self_guard -> g_version_guard [label="no"];
  g_self_installed -> g_version_guard [label="yes"];
  g_self_installed -> g_select [label="no: try next"];

  g_version_guard -> g_reverse_dep [label="yes"];
  g_version_guard -> g_select [label="no: try next"];

  g_reverse_dep -> g_pdepend [label="yes"];
  g_reverse_dep -> g_select [label="no: try next"];

  g_pdepend -> g_ctx_drop [label="yes"];
  g_pdepend -> g_use_guard [label="no"];
  g_ctx_drop -> g_use_guard;
  g_use_guard -> g_use_slot [label="yes"];
  g_use_guard -> g_select [label="no: try next"];

  g_use_slot -> g_bwu_ed_check;
  g_bwu_ed_check -> g_action_path [label="no conflict"];
  g_bwu_ed_check -> g_bwu_ed_fail [label="E/D conflict\ndetected"];
  g_bwu_ed_fail -> g_select [label="fail: try next\n(but requse_violation_\nmemo is set)"];

  g_action_path -> g_action_update [label="yes"];
  g_action_path -> g_action_install [label="no"];
  g_action_update -> g_emit;
  g_action_install -> g_emit;

  g_emit -> g_sel_policy [style=dashed, label="selection consistency policy"];
  g_emit -> g_split_emit [style=dashed, label="if split parent proving each child"];

  // Fallback chain (no viable candidate)
  g_slotreq -> g_deep_keep [style=dashed, label="no viable candidate branch"];
  g_deep_keep -> g_ok_deep [label="yes"];
  g_deep_keep -> g_requse_guard [label="no"];
  g_requse_guard -> g_reason_call [label="yes: skip reprove,\ngo straight to assumption"];
  g_requse_guard -> g_learn_parent [label="no: no USE violation"];
  g_learn_parent -> g_reprove [label="narrowing did not help\n(or not applicable)"];
  g_reprove -> g_reason_call [label="no reprove request\n(or not eligible)"];
  g_reprove -> r_throw [style=dashed, label="throw rules_reprove_cn_domain"];

  g_reason_call -> g_requse_ctx;
  g_requse_ctx -> g_slot_conflict_check [label="add required_use_violation\nto Ctx (if memo set)"];
  g_slot_conflict_check -> g_assume [label="add slot_conflict\nto Ctx (if memo set)"];

  // =========================================================================
  //  Edges: BWU cross-dep REQUIRED_USE check (:install / :run rules)
  // =========================================================================

  bwu_start -> bwu_check;
  bwu_check -> bwu_merge_ok;
  bwu_merge_ok -> bwu_requse_ok [label="yes"];
  bwu_merge_ok -> bwu_ed_viol [label="no: val_hook fails\n(E/D conflict)"];
  bwu_requse_ok -> bwu_update [label="yes"];
  bwu_requse_ok -> bwu_requse_viol [label="no: REQUIRED_USE\nviolated"];

  // Link BWU check to grouped_dep flow
  g_emit -> bwu_start [style=dashed, label="after :install/:run\ngoal emitted, BWU\nchecked before\nrequired_use resolution"];

  // =========================================================================
  //  Edges: cn_domain constraint unify hook (slot conflict detection)
  // =========================================================================

  cd_start -> cd_has_existing;
  cd_has_existing -> cd_put_new [label="no: first time"];
  cd_has_existing -> cd_meet [label="yes: merge"];
  cd_meet -> cd_meet_ok [label="yes"];
  cd_meet -> cd_meet_fail [label="no: incompatible\nversion domains"];
  cd_meet_fail -> g_slot_conflict_check [style=dashed, label="memo:slot_conflict_\nrecorded for\nassumption clause"];

  // =========================================================================
  //  Edges: CN-domain reprove retry loop
  // =========================================================================

  r_guard -> r_throw [style=dashed, label="reprove request"];
  r_throw -> r_catch;
  r_catch -> r_add;
  r_add -> r_retry;
  r_retry -> r_recurse [label="yes"];
  r_retry -> r_fallback [label="no"];
  r_recurse -> r_done [style=dashed, label="success/no further throw"];
  r_recurse -> r_catch [style=dashed, label="on next throw"];
  r_fallback -> r_done;

  // =========================================================================
  //  Edges: assumption reason diagnosis
  // =========================================================================

  e_start -> e_any;
  e_any -> e_missing [label="no"];
  e_any -> e_need_inst [label="yes"];
  e_need_inst -> e_inst_empty [label="yes"];
  e_need_inst -> e_unmasked1 [label="no"];
  e_inst_empty -> e_inst_req [label="yes"];
  e_inst_empty -> e_unmasked1 [label="no"];
  e_unmasked1 -> e_masked [label="no"];
  e_unmasked1 -> e_slot_any [label="yes"];
  e_slot_any -> e_slot_bad [label="no"];
  e_slot_any -> e_unmasked2 [label="yes"];
  e_unmasked2 -> e_masked [label="no"];
  e_unmasked2 -> e_versions [label="yes"];
  e_versions -> e_ver_nocand [label="none per constraint"];
  e_versions -> e_ver_conflict [label="constraints conflict"];
  e_versions -> e_keywords [label="has version-ok candidates"];
  e_keywords -> e_kw [label="no"];
  e_keywords -> e_other [label="yes (still failed)"];

  // =========================================================================
  //  Edges: update action path
  // =========================================================================

  u_start -> u_has_replaces;
  u_has_replaces -> u_txn [label="yes"];
  u_has_replaces -> u_installed_target [label="no"];
  u_installed_target -> u_delegate_latest [label="yes"];
  u_installed_target -> u_target_not_installed [label="no"];
  u_target_not_installed -> u_same_slot_old [label="yes"];
  u_target_not_installed -> u_noop [label="no"];
  u_same_slot_old -> u_txn [label="yes"];
  u_same_slot_old -> u_fallback_install [label="no"];
  u_txn -> u_txn_detail;

  // =========================================================================
  //  printer.pl : assumption_type/2 statistics bucketing
  // =========================================================================

  subgraph cluster_printer_type {
    label="assumption.pl : assumption_type/2 classification for statistics";
    color="#555555";
    fontcolor="#555555";

    at_start [shape=circle, label="assumption\nterm"];
    at_ctx_check [shape=diamond, label="has ?{Ctx} with\nassumption_reason(R)?"];
    at_requse_check [shape=diamond, style=filled, fillcolor="#ffe0e0",
                      label="has ?{Ctx} with\nrequired_use_violation(_)?"];
    at_slot_check [shape=diamond, style=filled, fillcolor="#e0e0ff",
                    label="has ?{Ctx} with\nslot_conflict(_)?"];
    at_requse_type [shape=box, style=filled, fillcolor="#ffe0e0",
                     label="Type = required_use_violation"];
    at_slot_type [shape=box, style=filled, fillcolor="#e0e0ff",
                   label="Type = slot_conflict"];
    at_reason_type [shape=box, label="assumption_reason_type(R, Type)\n─────────────────\nmissing → missing_dependency\nmasked → masked_dependency\nkeyword_filtered → keyword_filtered_dependency\nversion_conflict → version_conflict_dependency\nversion_no_candidate → version_no_candidate_dependency\nslot_unsatisfied → slot_unsatisfied_dependency\ninstalled_required → installed_required_dependency\nunsatisfied_constraints → unsatisfied_constraints_dependency"];
    at_generic [shape=box, label="generic unwrap:\n─────────────────\n?{Ctx} → strip wrapper\ndomain(X) → recurse\nfall through to:\n  non_existent_dependency\n  cycle_break\n  blocker_assumption\n  etc."];
    at_out [shape=note, label="Type atom\n(used in test_stats\nfor statistics\nbucketing)"];
  }

  // =========================================================================
  //  printer.pl : reason-aware plan step rendering
  // =========================================================================

  subgraph cluster_printer_suggestions {
    label="printer.pl / warning.pl : Suggestions section";
    color="#555555";
    fontcolor="#555555";

    sugg_section [shape=box, style=filled, fillcolor="#f5f5e0",
                  label="print_suggestions_section\n─────────────────\nWhen fallback tiers succeed, proof entries\ntagged with suggestion(...) in Context:\n• suggestion(accept_keyword, K) ← t_keyword\n• suggestion(unmask, _) ← t_unmask\n• suggestion(use_change, _, Changes)\n─────────────────\nPrints: package.accept_keywords,\npackage.unmask, package.use"];
  }

  subgraph cluster_printer_render {
    label="warning.pl : print_assumption_detail/1 reason-aware rendering";
    color="#555555";
    fontcolor="#555555";

    pr_start [shape=circle, label="assumed\nplan step"];
    pr_ctx_check [shape=diamond, label="has ?{Ctx} with\nassumption_reason(R)?"];
    pr_requse_check [shape=diamond, style=filled, fillcolor="#ffe0e0",
                      label="has ?{Ctx} with\nrequired_use_violation(V)?"];
    pr_slot_check [shape=diamond, style=filled, fillcolor="#e0e0ff",
                    label="has ?{Ctx} with\nslot_conflict(D)?"];
    pr_requse_render [shape=box, style=filled, fillcolor="#ffe0e0",
                       label="REQUIRED_USE violation:\nred 'verify' bubble\n─────────────────\n• requse_violation: shows forced\n  USE flags + violated constraint\n• use_flag_conflict: shows conflicting\n  flags (enabled + disabled sets)"];
    pr_slot_render [shape=box, style=filled, fillcolor="#e0e0ff",
                     label="Slot conflict:\nred 'verify' bubble\n─────────────────\n• domain_conflict: shows C/N with\n  conflicting version requirements\n  (e.g. =1.0 vs =1.1)\n• list entries: shows multiple versions\n  pulled into same slot"];
    pr_version_conflict [shape=box, style=filled, fillcolor="#fff3cc",
                         label="version_conflict:\nyellow 'verify' bubble\n(version conflict, assumed installed/running)"];
    pr_version_nocand [shape=box, style=filled, fillcolor="#fff3cc",
                       label="version_no_candidate:\nyellow 'verify' bubble\n(version unavailable, assumed installed/running)"];
    pr_slot_unsat [shape=box, style=filled, fillcolor="#fff3cc",
                   label="slot_unsatisfied:\nyellow 'verify' bubble\n(slot unavailable, assumed installed/running)"];
    pr_inst_req [shape=box, style=filled, fillcolor="#fff3cc",
                 label="installed_required:\nyellow 'verify' bubble\n(requires pre-installed, assumed installed)"];
    pr_unsat_constr [shape=box, style=filled, fillcolor="#fff3cc",
                     label="unsatisfied_constraints:\nyellow 'verify' bubble\n(constraints unsatisfied, assumed installed/running)"];
    pr_missing [shape=box, style=filled, fillcolor="#ffdddd",
                label="missing:\nred 'missing' bubble\n(non-existent, assumed installed/running)"];
    pr_generic [shape=box, style=filled, fillcolor="#e8e8e8",
                label="no reason / unknown:\nyellow 'non-existent' bubble\n(generic fallback)"];
  }

  // =========================================================================
  //  issue.pl : tree issue contextualisation
  // =========================================================================

  subgraph cluster_issue {
    label="issue.pl : tree issue notes";
    color="#888888";
    fontcolor="#888888";

    iss_start [shape=circle, label="(C,N,Deps)\nfrom assumption"];
    iss_known [shape=diamond, label="known_tree_issue(C,N,Note)?"];
    iss_known_note [shape=box, label="static Note\n(documented issue)"];
    iss_detect [shape=diamond, label="detect_version_range_gap\n(C,N,PackageDeps)?"];
    iss_gap_note [shape=box, label="generated Note:\n'Tree issue: version range gap\nfor C/N — no candidate satisfies\nthe combined version constraints.'"];
    iss_none [shape=box, label="no contextual note"];
    iss_output [shape=note, label="Note shown in\nDomain Assumptions\nsection of plan"];
  }

  // =========================================================================
  //  Cross-cluster edges
  // =========================================================================

  g_action_update -> u_start [style=dashed, label="when ActionGoal is update"];
  g_emit -> r_guard [style=dashed, label="constraint_guard may request reprove"];
  g_reason_call -> e_start [style=dashed, label="classification path"];
  t_blockers -> b_assume_blockers [style=dashed, label="sets rules_assume_blockers=true"];
  t_keyword -> g_select [style=dashed, label="accepted_keyword_candidate\naccepts ~arch"];
  t_unmask -> e_unmasked1 [style=dashed, label="bypasses package.mask"];

  // Assumption → printer type classification
  g_assume -> at_start [style=dashed, label="statistics"];
  at_start -> at_requse_check;
  at_requse_check -> at_requse_type [label="yes"];
  at_requse_check -> at_slot_check [label="no"];
  at_slot_check -> at_slot_type [label="yes"];
  at_slot_check -> at_ctx_check [label="no"];
  at_ctx_check -> at_reason_type [label="yes"];
  at_ctx_check -> at_generic [label="no"];
  at_requse_type -> at_out;
  at_slot_type -> at_out;
  at_reason_type -> at_out;
  at_generic -> at_out;

  // Fallback tiers → suggestions (when tier succeeds, proof tagged)
  t_keyword -> sugg_section [style=dashed, label="suggestion(accept_keyword)"];
  t_unmask -> sugg_section [style=dashed, label="suggestion(unmask)"];
  t_keyword_unmask -> sugg_section [style=dashed, label="both"];

  // Assumption → suggestions (collect_keyword_suggestions, collect_unmask_suggestions)
  g_assume -> sugg_section [style=dashed, label="assumptions with\nsuggestion tags"];

  // Assumption → printer rendering
  g_assume -> pr_start [style=dashed, label="plan output"];
  pr_start -> pr_requse_check;
  pr_requse_check -> pr_requse_render [label="yes:\nrequired_use_violation"];
  pr_requse_check -> pr_slot_check [label="no"];
  pr_slot_check -> pr_slot_render [label="yes:\nslot_conflict"];
  pr_slot_check -> pr_ctx_check [label="no"];
  pr_ctx_check -> pr_version_conflict [label="version_conflict"];
  pr_ctx_check -> pr_version_nocand [label="version_no_candidate"];
  pr_ctx_check -> pr_slot_unsat [label="slot_unsatisfied"];
  pr_ctx_check -> pr_inst_req [label="installed_required"];
  pr_ctx_check -> pr_unsat_constr [label="unsatisfied_constraints"];
  pr_ctx_check -> pr_missing [label="missing"];
  pr_ctx_check -> pr_generic [label="no reason"];

  // Assumption → issue contextualisation
  g_assume -> iss_start [style=dashed, label="tree issue notes"];
  iss_start -> iss_known;
  iss_known -> iss_known_note [label="yes"];
  iss_known -> iss_detect [label="no"];
  iss_detect -> iss_gap_note [label="yes"];
  iss_detect -> iss_none [label="no"];
  iss_known_note -> iss_output;
  iss_gap_note -> iss_output;

  // Explanation feeds into assumption_reason tagging
  e_missing -> g_assume [style=dashed, label="Reason=missing"];
  e_masked -> g_assume [style=dashed, label="Reason=masked"];
  e_slot_bad -> g_assume [style=dashed, label="Reason=slot_unsatisfied"];
  e_ver_nocand -> g_assume [style=dashed, label="Reason=version_no_candidate"];
  e_ver_conflict -> g_assume [style=dashed, label="Reason=version_conflict"];
  e_kw -> g_assume [style=dashed, label="Reason=keyword_filtered"];
  e_inst_req -> g_assume [style=dashed, label="Reason=installed_required"];
  e_other -> g_assume [style=dashed, label="Reason=unsatisfied_constraints"];
}
