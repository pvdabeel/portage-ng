digraph portage_ng_architecture {
  rankdir=TD;
  labelloc="t";
  label="portage-ng: full system architecture and data flow";
  fontsize=14;
  fontname="Helvetica";
  node [fontname="Helvetica", fontsize=10];
  edge [fontname="Helvetica", fontsize=9, arrowsize=0.7];

  // =========================================================================
  //  LAYER 1 вЂ” External inputs
  // =========================================================================

  subgraph cluster_inputs {
    label="External Inputs";
    style=dashed;
    color="#aaaaaa";
    fontcolor="#666666";

    portage_tree [shape=folder, label="Gentoo Portage Tree\n(metadata/md5-cache\n+ Manifest files)"];
    vdb_tree     [shape=folder, label="VDB\n(/var/db/pkg)"];
    profile_dir  [shape=folder, label="Profile + make.conf\n(USE, KEYWORDS, masks,\npackage.use, package.mask)"];
    world_file   [shape=folder, label="World file\n+ package sets"];
    user_target  [shape=note,   label="User target\ne.g. =sys-apps/portage-3.0"];
  }

  // =========================================================================
  //  LAYER 2 вЂ” Configuration & Infrastructure
  //            Source/ root В· Logic/ В· Security/ В· System/ В· Output/
  // =========================================================================

  subgraph cluster_infra {
    label="Configuration & Infrastructure\nSource/ root В· Logic/ В· Security/ В· System/ В· Output/ В· Knowledge/";
    color="#888888";
    fontcolor="#888888";
    style=rounded;

    config   [shape=box, style=filled, fillcolor="#e8e8e8",
              label="config.pl  [Source/]\nPaths, hostname, ports,\ngraph directory, TTY size"];
    os_mod   [shape=box, style=filled, fillcolor="#e8e8e8",
              label="os.pl  [System/]\nCross-platform OS interaction\n(locks, filesystem)"];
    context  [shape=box, style=filled, fillcolor="#e8e8e8",
              label="context.pl  [Logic/]\nDeclarative OOP framework\n(classes, instances, inheritance)"];
    message  [shape=box, style=filled, fillcolor="#e8e8e8",
              label="message.pl  [Output/]\nPretty-printing, debug\nmessaging, formatting"];
    stat     [shape=box, style=filled, fillcolor="#e8e8e8",
              label="stat.pl  [Knowledge/]\nProgress tracking,\ntiming, statistics"];
    sandbox  [shape=box, style=filled, fillcolor="#e8e8e8",
              label="sandbox.pl  [Security/]\nSafe predicate\ndeclarations"];
  }

  // =========================================================================
  //  LAYER 3 вЂ” Ingestion Pipeline  [Source/Pipeline/ + Domain/Gentoo/]
  // =========================================================================

  subgraph cluster_reader {
    label="Ingestion Pipeline  [Pipeline/ + Domain/Gentoo/]";
    color="#4477aa";
    fontcolor="#4477aa";
    style=rounded;

    reader  [shape=box, style=filled, fillcolor="#ddeeff",
             label="reader.pl  [Pipeline/]\nReads lines from md5-cache\nand manifest files"];
    parser  [shape=box, style=filled, fillcolor="#ddeeff",
             label="parser.pl  [Pipeline/]\nDrives EAPI grammar\nover file contents"];
    eapi    [shape=box, style=filled, fillcolor="#ddeeff",
             label="eapi.pl  [Domain/Gentoo/]\nDCG grammar (PMS 9)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDeps (DEPEND, RDEPEND,\n  BDEPEND, PDEPEND)\nUSE flags, USE_EXPAND\nSlot/subslot, versions\nREQUIRED_USE, blockers\nSRC_URI, license"];
  }

  // =========================================================================
  //  LAYER 4 вЂ” Knowledge Base  [Source/Knowledge/ + Domain/Gentoo/]
  // =========================================================================

  subgraph cluster_kb {
    label="Knowledge Base  [Knowledge/ + Domain/Gentoo/]";
    color="#44aa77";
    fontcolor="#44aa77";
    style=rounded;

    repository [shape=box, style=filled, fillcolor="#ddf5dd",
                label="repository.pl  [Knowledge/]\nSync, load, save\nportage tree operations"];
    kb         [shape=box, style=filled, fillcolor="#ddf5dd",
                label="knowledgebase.pl  [Knowledge/]\nRepositories register here;\nserializes to Knowledge/kb.qlf"];
    cache      [shape=cylinder, style=filled, fillcolor="#ddf5dd",
                label="cache.pl  [Knowledge/] вЂ” Dynamic fact store\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncache:entry/5           (repo, path, C, N, ver)\ncache:entry_metadata/4  (repo, entry, key, val)\ncache:ordered_entry/5   (sorted by version)\ncache:manifest/5        (distfile metadata)"];
    vdb        [shape=box, style=filled, fillcolor="#ddf5dd",
                label="vdb.pl  [Domain/Gentoo/]\nInstalled-package\nrepository (pkg://)"];
    pkg        [shape=box, style=filled, fillcolor="#ddf5dd",
                label="vdb.pl  [Domain/Gentoo/]\nInstalled package tracking;\nsync from /var/db/pkg"];
    profile    [shape=box, style=filled, fillcolor="#c8eac8",
                label="profile.pl  [Domain/Gentoo/]\nReads Gentoo profile dirs;\nglobal USE, masks, forces"];
    preference [shape=box, style=filled, fillcolor="#c8eac8",
                label="preference.pl  [Domain/Gentoo/]\nUSE flags, ACCEPT_KEYWORDS,\nmasks, package.use overrides"];
    set_mod    [shape=box, style=filled, fillcolor="#c8eac8",
                label="set.pl  [Domain/Gentoo/]\nPackage sets (world file,\nsystem set, user sets)\n[data: Knowledge/Sets/]"];
    query      [shape=box, style=filled, fillcolor="#c8eac8",
                label="query.pl  [Knowledge/] вЂ” Goal-expanded queries\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nquery:search/2\nquery:memoized_search/2\ngoal_expansion/2 macros\n(compile-time optimization)"];
    mirror     [shape=box, style=filled, fillcolor="#c8eac8",
                label="mirror.pl  [Domain/Gentoo/]\nDistfile mirrors;\nGLEP 75 layout"];
    ebuild_mod [shape=box, style=filled, fillcolor="#c8eac8",
                label="ebuild.pl  [Domain/Gentoo/]\nKB query sugar; download size\n+ Ebuild/ (ebuild-depend.sh,\n  ebuild_exec.pl)"];
  }

  // =========================================================================
  //  LAYER 5 вЂ” Prover (core solver)  [Pipeline/prover.pl + Pipeline/Prover/]
  // =========================================================================

  subgraph cluster_prover {
    label="Prover (proof search engine)  вЂ”  Pipeline/prover.pl + Prover/";
    color="#cc6644";
    fontcolor="#cc6644";
    style=rounded;

    prove_entry [shape=box, style="filled,bold", fillcolor="#ffeedd",
                 label="prover:prove/9\nMain entry point\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nInput:  Goals, empty AVLs (t)\nOutput: ProofAVL, ModelAVL,\n        ConstraintsAVL, TriggersAVL"];

    subgraph cluster_prover_core {
      label="Core Proof Loop";
      color="#dd9977";
      style=dashed;

      prove_once [shape=box, style=filled, fillcolor="#fff5ee",
                  label="prove_once\nFor each literal:\n  1. Look up rules:rule/2\n  2. Prove body conditions\n  3. Accumulate AVLs\n  4. Call literal_hook (PDEPEND)"];
      cycle_det  [shape=diamond, style=filled, fillcolor="#fff5ee",
                  label="Cycle?"];
      cycle_break [shape=box, style=filled, fillcolor="#ffdddd",
                   label="Cycle break\nassumed(rule(Lit))\nin ProofAVL\n(prover assumption)"];
      ctx_union  [shape=box, style=filled, fillcolor="#fff5ee",
                  label="ctx_union/3\nMerge contexts via\nfeature_unification:unify/3\n(strips self/1 for bounded growth)"];
    }

    subgraph cluster_constraints {
      label="Constraint System";
      color="#dd9977";
      style=dashed;

      constraint_avl [shape=cylinder, style=filled, fillcolor="#fff5ee",
                      label="ConstraintsAVL\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselected_cn(C,N)       вЂ” chosen version\nslot(C,N,S)            вЂ” slot lock\nuse(Entry)             вЂ” USE model\nblocked_cn(C,N)        вЂ” blocker specs\ncn_domain(C,N)         вЂ” version domain\ncn_domain_reason(C,N)  вЂ” diagnostic tags\nselected_cn_allow_multislot(C,N)"];
      constraint_guard [shape=box, style=filled, fillcolor="#ffeedd",
                        label="constraint_guard/2\nFires on constraint unification:\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў selected_cn uniqueness\n  (strict / per-slot / per-subslot)\nвЂў cn_domain в†” selected_cn compat\nвЂў blocked_cn в†” selected_cn source reprove\nвЂў slot consistency across deps"];
    }

    subgraph cluster_learning {
      label="Constraint Learning (Zeller-style)";
      color="#dd9977";
      style=dashed;

      learn [shape=box, style=filled, fillcolor="#ffe8cc",
             label="prover:learn/3\nPersist constraint across retries\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDomain narrowing\nParent narrowing"];
      learned_store [shape=cylinder, style=filled, fillcolor="#ffe8cc",
                     label="Learned Constraint Store\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nkey(C,N,Slot) в†’ version domain\nPersists across reprove retries\nNarrows candidate sets\n(Zeller feature-term approach)"];
    }

    subgraph cluster_reprove {
      label="CN-Domain Reprove Loop";
      color="#dd9977";
      style=dashed;

      reprove_catch [shape=box, style=filled, fillcolor="#fff5ee",
                     label="prove_with_cn_domain_retries/11\nCatch rules_reprove_cn_domain"];
      reject_store  [shape=cylinder, style=filled, fillcolor="#ffdddd",
                     label="Reject Store\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nkey(C,N,Domain)\n в†’ ordset(Rejected entries)\nScoped per top-level prove\n+ origin rejects (Vermeir)"];
      retry_check   [shape=diamond, style=filled, fillcolor="#fff5ee",
                     label="Attempt < Max\nв€§ new reject?"];
      final_pass    [shape=box, style=filled, fillcolor="#fff5ee",
                     label="Final pass\n(reprove disabled;\nassumptions allowed)"];
    }

    proof_out [shape=note, style=filled, fillcolor="#ffeedd",
               label="Output AVLs\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nProofAVL    вЂ” proof tree\n  rule(Lit) в†’ Body | assumed\nModelAVL   вЂ” proven contexts\nConstraintsAVL вЂ” accumulated\nTriggersAVL вЂ” dependency graph\n  Lit в†’ [dependent lits]"];
  }

  // =========================================================================
  //  LAYER 5b вЂ” Rules (domain logic)  [Domain/Gentoo/rules.pl + Rules/]
  // =========================================================================

  subgraph cluster_rules {
    label="Rules (domain-specific Gentoo logic)  [Domain/Gentoo/rules.pl + Rules/]";
    color="#8855aa";
    fontcolor="#8855aa";
    style=rounded;

    rule_hook [shape=box, style="filled,bold", fillcolor="#eeddff",
               label="rules.pl  [Domain/Gentoo/] вЂ” Declarative hub\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nrules:rule/2\nLit:Action?{Context} в†’ Conditions\nContext helpers (ctx_take_after,\nctx_strip_planning, etc.)\nProver overrides (assume_blockers,\nassume_conflicts)"];

    subgraph cluster_rules_sub {
      label="Rules Submodules  [Domain/Gentoo/Rules/]";
      color="#aa88cc";
      style=dashed;

      rule_candidate [shape=box, style=filled, fillcolor="#f5eeff",
                      label="candidate.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCandidate selection pipeline\nSlot merging & processing\nVersion coercion & CN-consistency\nBlocker matching & ranking\nDependency ordering"];
      rule_use       [shape=box, style=filled, fillcolor="#f5eeff",
                      label="use.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEffective USE resolution\nbuild_with_use propagation\nREQUIRED_USE satisfaction\n--newuse detection\nUSE conditionals (=, ?, !)"];
      rule_heuristic [shape=box, style=filled, fillcolor="#f5eeff",
                      label="heuristic.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDomain prover hooks:\nhandle_reprove, reprove_exhausted\nobligation_candidate\nSnapshot init/cleanup"];
      rule_dependency [shape=box, style=filled, fillcolor="#f5eeff",
                       label="dependency.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSelf-context injection\nUSE requirement collection\nSlot/build_with_use context\npropagation"];
      rule_target    [shape=box, style=filled, fillcolor="#f5eeff",
                      label="target.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTransactional update/downgrade\ncondition building\nDeep-update goal generation\nDependency CN extraction"];
      rule_memo      [shape=box, style=filled, fillcolor="#f5eeff",
                      label="memo.pl\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nThread-local caching facts\nclear_caches/0"];
    }

    rule_install [shape=box, style=filled, fillcolor="#f5eeff",
                  label="install rule\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRequired-USE model\nDependency model (grouped)\nadd_self_to_dep_contexts\nSlot/USE constraints\nDownload goal"];
    rule_run     [shape=box, style=filled, fillcolor="#f5eeff",
                  label="run rule\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRDEPEND resolution\nPDEPEND (single-pass\nvia literal_hook)"];
    rule_update  [shape=box, style=filled, fillcolor="#f5eeff",
                  label="update rule\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSame-slot upgrade /\ndowngrade / reinstall\nreplaces() context"];
    rule_grouped [shape=box, style=filled, fillcolor="#f5eeff",
                  label="grouped_package_dependency\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCandidate selection +\nconstraint emission"];
    rule_blocker [shape=box, style=filled, fillcolor="#f5eeff",
                  label="blocker rules\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWeak / strong blockers\nblocked_cn constraints\nassume_blockers mode"];
    rule_conflict [shape=box, style=filled, fillcolor="#f5eeff",
                   label="conflict rules\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSlot conflict detection\nassume_conflicts mode"];

    subgraph cluster_candidate {
      label="Candidate Selection Pipeline (candidate.pl)";
      color="#aa88cc";
      style=dashed;

      cand_steps  [shape=box, style=filled, fillcolor="#f5eeff",
                   label="1. Reuse selected_cn (if compatible)\n2. accepted_keyword_candidate\n3. Self-guard (avoid resolving to self)\n4. Version constraint check\n5. Effective domain check (cn_domain_rejects)\n6. Reverse-dep compatibility\n7. PDEPEND context stripping\n8. USE dep satisfaction (optenable/optdisable/=)\n9. build_with_use propagation\n10. Slot processing (process_slot)\n11. Update vs install action path"];
      multislot   [shape=box, style=filled, fillcolor="#f5eeff",
                   label="Multi-slot policy\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAllowed when:\nвЂў explicit slot dep (:N)\nвЂў any_same_slot (:=)\nвЂў any_different_slot\nвЂў exactish-versioned deps (~)\nвЂў version-constrained deps (в‰Ґ, <)"];
    }

    assumption   [shape=box, style=filled, fillcolor="#ffdddd",
                  label="Assumption fallback\nrule(assumed(X)) вЂ” domain assumption\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nmissing: no package exists\nmasked: all candidates masked\nversion_no_candidate / version_conflict\nslot_unsatisfied / installed_required\nkeyword_filtered\nunsatisfied_constraints\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCtx tagged with assumption_reason\nfor printer + statistics bucketing"];
    reprove_req  [shape=box, style=filled, fillcolor="#ffeedd",
                  label="Reprove request\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nmaybe_request_grouped_dep_reprove\nв†’ throw rules_reprove_cn_domain\nmaybe_learn_parent_narrowing\nв†’ narrow wrong-level origin"];

    subgraph cluster_support {
      label="Supporting Modules  [Domain/Gentoo/ + Logic/ + Pipeline/Prover/]";
      color="#aa88cc";
      style=dashed;

      version_domain [shape=box, style=filled, fillcolor="#f5eeff",
                      label="version.pl  [Domain/Gentoo/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndomain_meet/3 (intersection)\ndomain_consistent/1\ndomain_reason_terms/6\n(Zeller feature logic)"];
      feat_unify     [shape=box, style=filled, fillcolor="#f5eeff",
                      label="unify.pl  [Logic/]\n(feature_unification)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nunify/3 (context merge)\nFeature-term lattice"];
      explanation_m  [shape=box, style=filled, fillcolor="#f5eeff",
                      label="explanation.pl  [Pipeline/Prover/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nassumption_reason_for_\ngrouped_dep/6\n(classifies assumption type)"];
      explainer      [shape=box, style=filled, fillcolor="#f5eeff",
                      label="explainer.pl  [Pipeline/Prover/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nwhy_in_plan/5,6\nwhy_in_proof/3,4\nwhy_assumption/4,5\nexplain/2,3 в†’ LLM\n(introspection + explanation)"];
      issue_mod      [shape=box, style=filled, fillcolor="#f5eeff",
                      label="issue.pl  [Domain/Gentoo/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nknown_tree_issue/3\ndetect_version_range_gap/3\ntree_issue_context/4\n(tree issue contextualisation)"];
    }
  }

  // =========================================================================
  //  LAYER 5c вЂ” Pipeline (orchestration)  [Pipeline/pipeline.pl]
  // =========================================================================

  subgraph cluster_pipeline {
    label="Pipeline (orchestration)  вЂ”  Pipeline/pipeline.pl";
    color="#668844";
    fontcolor="#668844";
    style=rounded;

    pipeline [shape=box, style="filled,bold", fillcolor="#e8f5e8",
              label="pipeline.pl  [Pipeline/] вЂ” Prove + Plan + Schedule\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nprove_plan / prove_plan_basic\nprove_plan_with_fallback\nprove_with_fallback (prove only)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFallback chain (production + tests):\n  1. strict\n  2. keyword_acceptance\n  3. blockers\n  4. unmask\n  5. keyword_acceptance + unmask"];
  }

  // =========================================================================
  //  LAYER 6 вЂ” Planner / Scheduler  [Pipeline/]
  // =========================================================================

  subgraph cluster_planning {
    label="Planning & Scheduling  [Pipeline/ + Pipeline/Planner/]";
    color="#338866";
    fontcolor="#338866";
    style=rounded;

    planner [shape=box, style=filled, fillcolor="#ddffee",
             label="planner.pl  [Pipeline/] вЂ” Wave planning (acyclic)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nInput:  ProofAVL, TriggersAVL\nAlgorithm: Initialize dep counts,\n  process ready rules in waves\nOutput: Plan (list of parallel waves)\n        + RemainderRules (cyclic portion)"];
    scheduler [shape=box, style=filled, fillcolor="#ddffee",
               label="scheduler.pl  [Pipeline/] вЂ” SCC scheduling (cyclic)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nKosaraju SCC decomposition\nMerge-set for :run SCCs\nSchedule :install/:update in SCCs\nEnforce after_only ordering\nOutput: Final ordered plan\n        + unschedulable remainder"];
    plan_out [shape=note, style=filled, fillcolor="#ddffee",
              label="Final Plan\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOrdered waves of actions:\ndownload в†’ install в†’ run\nupdate / reinstall\n+ unschedulable remainder"];
  }

  // =========================================================================
  //  LAYER 7 вЂ” Interface / Printer / Output
  //            Source/interface.pl В· Interface/ В· Output/ В· Pipeline/Printer/
  // =========================================================================

  subgraph cluster_output {
    label="Interface & Output\nSource/interface.pl В· Interface/ В· Output/ В· Pipeline/Printer/";
    color="#555555";
    fontcolor="#555555";
    style=rounded;

    interface [shape=box, style=filled, fillcolor="#eeeeee",
               label="interface.pl + Interface/  [Source/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCLI: spec, argv, flags, verify\n+ action.pl в†’ 15 Action/ handlers\n  (sync, graph, merge, build,\n   search, info, upgrade, вЂ¦)\n+ target.pl (target resolution)\nModes: --pretend, --graph,\n  --shell, --sync, --ci\nExit codes: 0/1/2"];
    printer [shape=box, style=filled, fillcolor="#eeeeee",
             label="printer.pl + Printer/  [Pipeline/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nStep-by-step plan with actions\nReason-aware assumption display:\n  version_conflict, slot_unsatisfied,\n  keyword_filtered, masked, missing,\n  unsatisfied_constraints, вЂ¦\nBlockers, cycle-breaks\nSuggestions (unmask/keyword/USE)\nTree issue contextualisation\nDownload size totals\nUSE flag display\n+ Plan/ Build/ News/ index\n  info stats state"];
    grapher [shape=box, style=filled, fillcolor="#eeeeee",
             label="grapher.pl + Grapher/  [Output/]\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIterates all targets\n--graph full / --graph partial\nWrites .merge files\nParallel via worker threads\n+ Report/report.pl"];
    terminal [shape=note, label="Terminal output\nor .merge files\n(Graph directory)"];
  }

  // =========================================================================
  //  LAYER 8 вЂ” Execution & Operations
  //            Pipeline/builder.pl + Builder/ В· Domain/Gentoo/
  // =========================================================================

  subgraph cluster_execution {
    label="Execution & Operations\nPipeline/builder.pl + Builder/ В· Pipeline/Planner/ В· Domain/Gentoo/";
    color="#996633";
    fontcolor="#996633";
    style=rounded;

    builder [shape=box, style=filled, fillcolor="#f5e6d0",
             label="builder.pl + Builder/  [Pipeline/]\nExecutes plans: build steps,\nebuild phases, downloads\n+ download.pl, jobserver.pl,\n  snapshot.pl, buildtime.pl"];
    worker  [shape=box, style=filled, fillcolor="#f5e6d0",
             label="worker.pl  [Mode/]\nMulti-threaded worker pool;\njob queues for parallel proofs"];
    script  [shape=box, style=filled, fillcolor="#f5e6d0",
             label="script.pl  [System/]\nExecutes scripts from\nSystem/Scripts/ directory"];
    depclean [shape=box, style=filled, fillcolor="#f5e6d0",
              label="depclean.pl  [Domain/Gentoo/]\nProof-based depclean;\nfinds removable packages"];
    kahn     [shape=box, style=filled, fillcolor="#f5e6d0",
              label="kahn.pl  [Pipeline/Planner/]\nTopological sort\n(Kahn's algorithm)"];
  }

  // =========================================================================
  //  LAYER 9 вЂ” Network / Distributed  [Mode/ + Llm/ + System/]
  // =========================================================================

  subgraph cluster_network {
    label="Network & Distributed  [Mode/ + Llm/ + System/]";
    color="#447799";
    fontcolor="#447799";
    style=rounded;

    server  [shape=box, style=filled, fillcolor="#dde8f0",
             label="server.pl  [Mode/]\nPengine HTTP server;\nendpoints: /sync, /prove,\n/save, /load, /plan"];
    client  [shape=box, style=filled, fillcolor="#dde8f0",
             label="client.pl  [Mode/]\nPengine client;\nremote predicate calls"];
    stubs   [shape=box, style=filled, fillcolor="#dde8f0",
             label="stubs.pl  [Mode/]\nMode-specific stubs;\navoids undefined errors"];
    bonjour [shape=box, style=filled, fillcolor="#dde8f0",
             label="bonjour.pl  [System/]\nmDNS service discovery;\nauto-detect cluster nodes"];
    cluster [shape=box, style=filled, fillcolor="#dde8f0",
             label="cluster.pl  [Mode/]\nDistributed proving;\njob/result queues\nacross nodes"];
    llm     [shape=box, style=filled, fillcolor="#dde8f0",
             label="llm.pl [Source/] + Llm/\nLLM integration (claude, chatgpt,\ngemini, grok, ollama)\n+ explain.pl, semantic.pl\nStreaming, code execution,\nerror explanation"];
  }

  // =========================================================================
  //  LAYER 10 вЂ” Testing  [Source/Test/]
  // =========================================================================

  subgraph cluster_testing {
    label="Testing  [Source/Test/]";
    color="#669966";
    fontcolor="#669966";
    style=rounded;

    tester [shape=box, style=filled, fillcolor="#e0f0e0",
            label="tester.pl\nTest runner;\ntrace-to-string"];
    test   [shape=box, style=filled, fillcolor="#e0f0e0",
            label="test.pl + unittest.pl\nTest cases, expectations,\nxfail markers\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n207 PLUnit tests + prover/\nplanner/scheduler integration\nuse pipeline:prove_with_fallback\n(same fallback as production)"];
  }

  // =========================================================================
  //  EDGES вЂ” Data flow
  // =========================================================================

  // External в†’ System
  portage_tree -> reader    [label="md5-cache +\nManifest"];
  vdb_tree     -> pkg       [label="installed pkgs"];
  profile_dir  -> profile   [label="USE, masks,\nforces"];
  world_file   -> set_mod   [label="world entries"];
  user_target  -> interface [label="target atom"];

  // Ingestion
  reader -> parser [label="lines"];
  parser -> eapi   [label="char codes"];
  eapi   -> cache  [label="assert parsed facts"];

  // Repository mgmt
  repository -> reader [label="triggers read"];
  repository -> kb     [label="registers repo"];
  kb -> cache          [label="serialize (Knowledge/kb.qlf)"];

  // VDB
  vdb -> cache [label="pkg:// entries"];
  pkg -> vdb   [label="sync"];

  // KB queries
  cache -> query      [label="backing store"];
  vdb   -> query      [label="pkg:// queries"];
  profile -> preference [label="global USE"];
  preference -> query [label="USE/KEYWORDS\nfiltering"];
  set_mod -> interface [label="world targets", style=dashed];
  mirror -> printer    [label="distfile URLs", style=dashed];
  ebuild_mod -> query  [label="sugar", style=dashed];

  // Interface orchestrates
  interface -> pipeline   [label="prove_plan_with_fallback"];
  interface -> grapher    [label="--graph mode"];

  // Pipeline orchestrates prove в†’ plan в†’ schedule (with fallback)
  pipeline -> prove_entry [label="prove(Goals,...)"];
  pipeline -> planner     [label="plan(Proof,Triggers,...)"];
  pipeline -> scheduler   [label="schedule(...)"];

  // Grapher
  grapher -> printer      [label="per-target\nprove+plan+print"];
  grapher -> worker       [label="parallel\nthreads", style=dashed];
  grapher -> terminal     [label=".merge files"];

  // Prover core
  prove_entry -> reprove_catch;
  reprove_catch -> prove_once;
  prove_once -> cycle_det;
  cycle_det -> cycle_break [label="yes"];
  cycle_det -> ctx_union   [label="no"];
  cycle_break -> prove_once [style=dashed];
  ctx_union -> prove_once   [style=dashed];

  // Prover в†’ Rules
  prove_once -> rule_hook [label="rules:rule/2"];

  // Rule dispatch
  rule_hook -> rule_install;
  rule_hook -> rule_run;
  rule_hook -> rule_update;
  rule_hook -> rule_grouped;
  rule_hook -> rule_blocker;
  rule_hook -> rule_conflict;

  // Submodule usage
  rule_grouped -> rule_candidate [label="selection +\nslot logic", style=dashed];
  rule_install -> rule_use       [label="USE evaluation", style=dashed];
  rule_install -> rule_dependency [label="context\npropagation", style=dashed];
  rule_update  -> rule_target    [label="txn conditions", style=dashed];
  rule_hook    -> rule_memo      [style=dashed, label="cache lookups"];
  rule_hook    -> rule_heuristic [style=dashed, label="reprove hooks"];

  // Grouped dep
  rule_grouped -> cand_steps;
  cand_steps -> multislot [style=dashed];
  cand_steps -> reprove_req [label="no viable\ncandidate"];
  reprove_req -> assumption [label="reprove\nexhausted"];
  cand_steps -> query [label="version/slot/USE\nlookups", style=dashed];

  // Reprove loop
  reprove_req -> reprove_catch [label="throw", style=dashed, color="#cc4444"];
  constraint_guard -> reprove_catch [label="throw", style=dashed, color="#cc4444"];
  reprove_catch -> reject_store [label="add rejects"];
  reject_store -> retry_check;
  retry_check -> prove_once [label="retry"];
  retry_check -> final_pass [label="exhausted"];

  // Constraints
  prove_once -> constraint_avl [style=dashed, label="emit"];
  constraint_avl -> constraint_guard [label="on unify"];
  constraint_guard -> learn [label="learn", style=dashed, color="#cc8844"];
  learn -> learned_store;
  learned_store -> cand_steps [label="narrow\ncandidates", style=dashed, color="#cc8844"];
  reject_store -> cand_steps  [label="filter\nrejected", style=dashed, color="#cc4444"];

  // Rules support
  rule_install -> query [style=dashed];
  rule_run -> query [style=dashed];
  cand_steps -> version_domain [style=dashed];
  ctx_union -> feat_unify [style=dashed];
  assumption -> explanation_m [style=dashed, label="classify"];
  explanation_m -> explainer [style=dashed];
  issue_mod -> printer       [style=dashed, constraint=false, label="tree issue\ncontextualisation"];
  explanation_m -> issue_mod [style=dashed, label="known issue\nlookup"];

  // Prover output
  prove_once -> proof_out [style=dashed, label="final AVLs"];

  // Planning
  proof_out -> planner [label="ProofAVL +\nTriggersAVL"];
  planner -> scheduler [label="Plan +\nRemainder"];
  scheduler -> plan_out;

  // Output
  plan_out -> printer    [label="final plan"];
  proof_out -> printer   [label="Model + Proof", style=dashed];
  printer -> terminal    [label="formatted\noutput"];
  printer -> message     [style=dashed, label="formatting"];
  printer -> stat        [style=dashed, label="timing"];

  // Execution
  builder -> printer   [style=dashed, label="reads plan"];
  builder -> script    [style=dashed, label="run scripts"];
  worker -> prove_entry [style=dashed, label="parallel proofs"];

  // Network
  server -> prove_entry [style=dashed, label="/prove endpoint"];
  client -> server      [label="pengine RPC"];
  bonjour -> cluster    [style=dashed, label="discover nodes"];
  cluster -> client     [label="distribute jobs"];
  llm -> printer        [style=dashed, label="explain errors"];
  llm -> explainer      [style=dashed, label="explain/2,3"];

  // Testing
  tester -> pipeline   [style=dashed, label="prove_with_fallback"];
  test -> tester       [label="test cases"];

  // Depclean
  depclean -> prove_entry [style=dashed, label="prove required"];
  depclean -> set_mod     [style=dashed, label="world roots"];
  depclean -> kahn        [style=dashed, label="topo sort"];

  // Infrastructure connections
  config -> repository [style=dashed];
  config -> interface  [style=dashed];
  os_mod -> repository [style=dashed];
}
