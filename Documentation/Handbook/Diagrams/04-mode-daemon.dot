digraph mode_daemon {
  rankdir=LR;
  fontname="Helvetica Neue";
  node [fontname="Helvetica Neue", fontsize=10, style=filled];
  edge [fontname="Helvetica Neue", fontsize=9];
  compound=true;

  subgraph cluster_machine {
    label="Local machine";
    labeljust=l;
    style="rounded";
    color="#8E44AD";
    fontsize=11;
    fontcolor="#8E44AD";
    fillcolor="#F4ECF7";

    proc1 [label="portage-ng\n(client call 1)", shape=box, fillcolor="#FFF3CD"];
    proc2 [label="portage-ng\n(client call 2)", shape=box, fillcolor="#FFF3CD"];
    proc3 [label="portage-ng\n(client call N)", shape=box, fillcolor="#FFF3CD"];

    sock [label="Unix Socket", shape=diamond, fillcolor="#E8E8E8"];

    subgraph cluster_daemon {
      label="portage-ng (daemon)  —  started once, stays resident";
      labeljust=l;
      style="rounded,dashed";
      color="#888888";
      fontsize=9;

      kb     [label="Knowledge Base\n(loaded once at startup)", shape=cylinder, fillcolor="#D4EDDA"];
      prover [label="Prover → Planner\n→ Scheduler", shape=box, fillcolor="#CCE5FF"];
    }

    proc1 -> sock;
    proc2 -> sock;
    proc3 -> sock [style=dashed];
    sock -> prover [label="goal"];
    kb -> prover [label="query", style=dashed];
    prover -> sock [label="result", style=dashed];
  }
}
