digraph mode_workers {
  rankdir=TB;
  fontname="Helvetica Neue";
  node [fontname="Helvetica Neue", fontsize=10, style=filled];
  edge [fontname="Helvetica Neue", fontsize=9];
  compound=true;

  // Server machine
  subgraph cluster_server {
    label="Server machine";
    labeljust=l;
    style="rounded";
    color="#2980B9";
    fontsize=11;
    fontcolor="#2980B9";
    fillcolor="#EBF5FB";

    server [label="portage-ng\n(server)", shape=box, fillcolor="#CCE5FF"];
    kb     [label="Knowledge\nBase", shape=cylinder, fillcolor="#D4EDDA"];
    queue  [label="Job Queue\n+ Results", shape=box, fillcolor="#FADBD8"];
    bonjour_s [label="Bonjour\n(mDNS advertise)", shape=ellipse, fillcolor="#E8E8E8"];

    server -> queue;
    kb -> server [style=dashed];
    server -> bonjour_s [style=dashed];
  }

  // Worker 1
  subgraph cluster_w1 {
    label="Worker machine 1";
    labeljust=l;
    style="rounded";
    color="#27AE60";
    fontsize=11;
    fontcolor="#27AE60";
    fillcolor="#EAFAF1";

    w1 [label="portage-ng\n(worker)", shape=box, fillcolor="#CCE5FF"];
    w1_kb [label="Local KB\n(synced copy)", shape=cylinder, fillcolor="#D4EDDA"];
    w1_tree [label="Portage tree\n(git snapshot)", shape=folder, fillcolor="#E8E8E8"];
    w1_bonj [label="Bonjour\n(mDNS discover)", shape=ellipse, fillcolor="#E8E8E8"];

    w1_tree -> w1_kb [label="--sync", style=dashed];
    w1_kb -> w1 [style=dashed];
  }

  // Worker 2
  subgraph cluster_w2 {
    label="Worker machine 2";
    labeljust=l;
    style="rounded";
    color="#27AE60";
    fontsize=11;
    fontcolor="#27AE60";
    fillcolor="#EAFAF1";

    w2 [label="portage-ng\n(worker)", shape=box, fillcolor="#CCE5FF"];
    w2_kb [label="Local KB\n(synced copy)", shape=cylinder, fillcolor="#D4EDDA"];
    w2_tree [label="Portage tree\n(git snapshot)", shape=folder, fillcolor="#E8E8E8"];
    w2_bonj [label="Bonjour\n(mDNS discover)", shape=ellipse, fillcolor="#E8E8E8"];

    w2_tree -> w2_kb [label="--sync", style=dashed];
    w2_kb -> w2 [style=dashed];
  }

  // Worker N
  subgraph cluster_wn {
    label="Worker machine N";
    labeljust=l;
    style="rounded";
    color="#27AE60";
    fontsize=11;
    fontcolor="#27AE60";
    fillcolor="#EAFAF1";

    wn [label="portage-ng\n(worker)", shape=box, fillcolor="#CCE5FF"];
    wn_kb [label="Local KB\n(synced copy)", shape=cylinder, fillcolor="#D4EDDA"];
    wn_tree [label="Portage tree\n(git snapshot)", shape=folder, fillcolor="#E8E8E8"];
    wn_bonj [label="Bonjour\n(mDNS discover)", shape=ellipse, fillcolor="#E8E8E8"];

    wn_tree -> wn_kb [label="--sync", style=dashed];
    wn_kb -> wn [style=dashed];
  }

  // Bonjour discovery
  w1_bonj -> bonjour_s [label="discover\nserver", style=dashed, color="#888888"];
  w2_bonj -> bonjour_s [label="discover", style=dashed, color="#888888"];
  wn_bonj -> bonjour_s [label="discover", style=dashed, color="#888888"];

  // Job flow
  queue -> w1 [label="job", style=bold, color="#CC0000"];
  queue -> w2 [label="job", style=bold, color="#CC0000"];
  queue -> wn [label="job", style="bold,dashed", color="#CC0000"];
  w1 -> queue [label="result", style=dashed, color="#CC0000"];
  w2 -> queue [label="result", style=dashed, color="#CC0000"];
  wn -> queue [label="result", style=dashed, color="#CC0000"];
}
