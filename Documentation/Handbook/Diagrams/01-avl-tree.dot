// AVL tree example — looking up 'ssl' by comparison, not scanning
// Used in Chapter 1 (Introduction), section 1.3.5
// Two-column layout: steps on the left, tree on the right (both top-down)

digraph avl_tree {
    rankdir=TB
    bgcolor=transparent
    node [fontname="Helvetica Neue" fontsize=12]
    edge [fontname="Helvetica Neue" fontsize=10]
    nodesep=0.5
    ranksep=0.7

    // Title
    labelloc=t
    label=<
        <table border="0" cellpadding="2">
        <tr><td><font face="Helvetica Neue" point-size="12"><b>Looking up "ssl" — 3 comparisons instead of 7</b></font></td></tr>
        </table>
    >

    // Steps — three separate nodes aligned vertically on the left
    node [shape=plaintext fillcolor=transparent color=transparent
          fixedsize=false width=2.6 height=0.3]

    s1 [label=<
        <table border="0" cellpadding="3" cellspacing="0">
        <tr><td align="left" width="50"><font face="Helvetica Neue" point-size="11"><b>Step 1</b></font></td>
            <td align="left"><font face="Helvetica Neue" point-size="10">"ssl" &gt; "gtk" → go right</font></td></tr>
        </table>
    >]

    s2 [label=<
        <table border="0" cellpadding="3" cellspacing="0">
        <tr><td align="left" width="50"><font face="Helvetica Neue" point-size="11"><b>Step 2</b></font></td>
            <td align="left"><font face="Helvetica Neue" point-size="10">"ssl" &gt; "net" → go right</font></td></tr>
        </table>
    >]

    s3 [label=<
        <table border="0" cellpadding="3" cellspacing="0">
        <tr><td align="left" width="50"><font face="Helvetica Neue" point-size="11"><b>Step 3</b></font></td>
            <td align="left"><font face="Helvetica Neue" point-size="10">"ssl" = "ssl" → found!</font></td></tr>
        </table>
    >]

    // Tree nodes — regular (not visited)
    node [shape=circle width=0.55 fixedsize=true style=filled
          fillcolor="#f0f0f0" color="#bbbbbb" fontcolor="#888888"]
    css    [label="css"]
    app    [label="app"]
    editor [label="editor"]
    jpeg   [label="jpeg"]

    // Tree nodes — lookup path (visited)
    node [fillcolor="#d5e8d4" color="#27ae60" penwidth=2 fontcolor="#1a1a1a"]
    gtk  [label="gtk"]
    net  [label="net"]
    ssl  [label="ssl" fillcolor="#27ae60" fontcolor="white"]

    // Regular tree edges
    edge [color="#cccccc" penwidth=1.0]
    gtk -> css
    css -> app
    css -> editor
    net -> jpeg

    // Lookup path edges
    edge [color="#27ae60" penwidth=2.5]
    gtk -> net
    net -> ssl

    // Align steps with tree levels, steps first for left placement
    { rank=same; s1; gtk }
    { rank=same; s2; css; net }
    { rank=same; s3; app; editor; jpeg; ssl }

    // Vertical chain for steps
    edge [style=invis]
    s1 -> s2 -> s3

    // Force left ordering
    edge [style=invis]
    s1 -> gtk [weight=0]
    s2 -> css [weight=0]
    s3 -> app [weight=0]
}
