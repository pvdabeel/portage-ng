// Chapter 10 — Meet example 3: disjoint (conflict)
// Render: dot -Tsvg 10-domain-meet-ex3.dot -o 10-domain-meet-ex3.svg
digraph ex3 {
    rankdir=LR;
    fontname="Helvetica Neue"; fontsize=9;
    node [fontname="Helvetica Neue", fontsize=8, style=filled, shape=box, margin="0.06,0.04"];
    edge [arrowsize=0.5];
    nodesep=0.15; ranksep=0.25;
    d1 [label=">=2.0", fillcolor="#cce5ff"];
    d2 [label="<1.0", fillcolor="#cce5ff"];
    m  [label="meet", fillcolor="#e8e8e8"];
    r  [label="FAIL", fillcolor="#f8d7da"];
    d1 -> m; d2 -> m; m -> r;
}
