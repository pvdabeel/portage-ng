digraph mode_standalone {
  rankdir=LR;
  fontname="Helvetica Neue";
  node [fontname="Helvetica Neue", fontsize=10, style=filled];
  edge [fontname="Helvetica Neue", fontsize=9];
  compound=true;

  subgraph cluster_machine {
    label="Local machine";
    labeljust=l;
    style="rounded";
    color="#27AE60";
    fontsize=11;
    fontcolor="#27AE60";
    fillcolor="#EAFAF1";

    user [label="User", shape=house, fillcolor="#FFF3CD"];

    subgraph cluster_process {
      label="portage-ng (standalone)";
      labeljust=l;
      style="rounded,dashed";
      color="#888888";
      fontsize=9;

      kb     [label="Knowledge\nBase", shape=cylinder, fillcolor="#D4EDDA"];
      prover [label="Prover", shape=box, fillcolor="#CCE5FF"];
      planner [label="Planner", shape=box, fillcolor="#CCE5FF"];
      scheduler [label="Scheduler", shape=box, fillcolor="#CCE5FF"];
      printer [label="Printer /\nBuilder", shape=box, fillcolor="#CCE5FF"];
    }

    tree [label="Portage tree\n+ VDB\n+ /etc/portage", shape=folder, fillcolor="#E8E8E8"];

    user -> prover [label="goals"];
    kb -> prover [label="query", style=dashed];
    prover -> planner -> scheduler -> printer;
    tree -> kb [label="--sync", style=dashed];
  }
}
