// Chapter 10 — Meet example 2: two lower bounds
// Render: dot -Tsvg 10-domain-meet-ex2.dot -o 10-domain-meet-ex2.svg
digraph ex2 {
    rankdir=LR;
    fontname="Helvetica Neue"; fontsize=9;
    node [fontname="Helvetica Neue", fontsize=8, style=filled, shape=box, margin="0.06,0.04"];
    edge [arrowsize=0.5];
    nodesep=0.15; ranksep=0.25;
    d1 [label=">=1.0", fillcolor="#cce5ff"];
    d2 [label=">=1.5", fillcolor="#cce5ff"];
    m  [label="meet", fillcolor="#e8e8e8"];
    r  [label=">=1.5", fillcolor="#d4edda"];
    d1 -> m; d2 -> m; m -> r;
}
