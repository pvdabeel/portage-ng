digraph test16 {
  label="test16 \u2014 Explicit all-of group ( )";
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];

  app [label="app-1.0"];
  db [label="db-1.0"];
  g1 [label="all-of",shape=diamond,fillcolor=lightyellow,fontsize=9,width=0.4,height=0.4];
  os [label="os-1.0"];
  web [label="web-1.0",fillcolor=lightcoral,fontcolor=white];

  app -> os;
  app -> db;
  db -> os;
  web -> os;
  web -> app;
  web -> g1;
  g1 -> db;
  g1 -> os;
}