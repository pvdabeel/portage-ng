digraph test69 {
  label=<<B>test69</B> — Version &gt;=>;
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR,compound=true];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];
  edge  [fontname=Helvetica,fontsize=9];

  subgraph cluster_lib {
    label="lib"; style=dashed; color=gray;
    lib1 [label="lib-1.0"];
    lib2 [label="lib-2.0"];
    lib3 [label="lib-3.0",fillcolor=palegreen];
    lib4 [label="lib-4.0",fillcolor=palegreen];
    lib5 [label="lib-5.0",fillcolor=palegreen];
  }

  app [label="app-1.0",fillcolor=lightcoral,fontcolor=white];

  app -> lib3 [lhead=cluster_lib,label=">=3.0"];
}