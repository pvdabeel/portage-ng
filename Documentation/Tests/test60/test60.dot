digraph test60 {
  label=<<B>test60</B> — Versioned blocker (XFAIL)>;
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];
  edge  [fontname=Helvetica,fontsize=9];

  web [label="web-1.0",fillcolor=lightcoral,fontcolor=white];
  app [label="app-1.0"];
  db [label="db-1.0"];
  os [label="os-1.0"];
  g1 [label="||",shape=diamond,fillcolor=orange,fontcolor=white,fontsize=11,width=0.5,height=0.5];
  windows1 [label="windows-1.0"];
  windows2 [label="windows-2.0"];

  web -> app;
  web -> db;
  web -> os;
  app -> os;
  app -> db;
  app -> windows1 [color=red,style=dashed,label="!<2.0",fontcolor=red];
  db -> os;
  os -> g1;
  g1 -> windows1 [label="=1.0"];
  g1 -> windows2 [label="=2.0"];
}