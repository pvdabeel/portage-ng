digraph test75 {
  label=<<B>test75</B> — Reinstall / emptytree (VDB)>;
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];
  edge  [fontname=Helvetica,fontsize=9];

  app [label="app-1.0",fillcolor=lightcoral,fontcolor=white];
  os [label="os-1.0",fillcolor=lightblue];

  app -> os;
}