digraph test13 {
  label=<<B>test13</B> — Pinpointed version =pkg-ver>;
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];
  edge  [fontname=Helvetica,fontsize=9];

  web [label="web-2.0",fillcolor=lightcoral,fontcolor=white];
  app [label="app-2.0"];
  db [label="db-2.0"];
  os [label="os-1.0"];

  web -> app [label="=app-2.0"];
  web -> db [label="=db-2.0"];
  web -> os;
  app -> db [label="=db-2.0"];
  app -> os;
  db -> os;
}