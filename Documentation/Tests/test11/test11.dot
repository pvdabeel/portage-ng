digraph test11 {
  label="test11 \u2014 Missing dep (compile+runtime)";
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];

  app [label="app-1.0"];
  db [label="db-1.0"];
  notexists [label="notexists",style="rounded,dashed,filled",fillcolor=mistyrose];
  os [label="os-1.0",fillcolor=lightcoral,fontcolor=white];
  web [label="web-1.0"];

  app -> os;
  app -> db;
  db -> os;
  os -> notexists;
  web -> os;
  web -> app;
  web -> db;
}