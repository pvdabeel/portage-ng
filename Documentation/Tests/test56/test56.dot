  lib_2_0 [label="lib-2.0"];
  lib_3_0 [label="lib-3.0"];
  lib_4_0 [label="lib-4.0"];
  lib_5_0 [label="lib-5.0"];
  lib_6_0 [label="lib-6.0"];
  lib_7_0 [label="lib-7.0"];
  lib_8_0 [label="lib-8.0"];
  lib_9_0 [label="lib-9.0"];
  modulea [label="modulea-1.0"];
  moduleb [label="moduleb-1.0"];

  app -> modulea;
  app -> moduleb;
  modulea -> lib_1_0 [label=">lib-3"];
  modulea -> lib_2_0 [label=">lib-3"];
  modulea -> lib_3_0 [label=">lib-3"];
  modulea -> lib_4_0 [label=">lib-3"];
  modulea -> lib_5_0 [label=">lib-3"];
  modulea -> lib_6_0 [label=">lib-3"];
  modulea -> lib_7_0 [label=">lib-3"];
  modulea -> lib_8_0 [label=">lib-3"];
  modulea -> lib_9_0 [label=">lib-3"];
  moduleb -> lib_1_0 [label="<lib-7"];
  moduleb -> lib_2_0 [label="<lib-7"];
  moduleb -> lib_3_0 [label="<lib-7"];
  moduleb -> lib_4_0 [label="<lib-7"];
  moduleb -> lib_5_0 [label="<lib-7"];
  moduleb -> lib_6_0 [label="<lib-7"];
  moduleb -> lib_7_0 [label="<lib-7"];
  moduleb -> lib_8_0 [label="<lib-7"];
  moduleb -> lib_9_0 [label="<lib-7"];
}