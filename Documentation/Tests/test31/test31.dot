digraph test31 {
  label="test31 \u2014 Weak blocker ! (both)";
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];

  app [label="app-1.0"];
  bsd [label="bsd-1.0"];
  db [label="db-1.0"];
  g1 [label="||",shape=diamond,fillcolor=lightyellow,fontsize=9,width=0.4,height=0.4];
  linux [label="linux-1.0"];
  os [label="os-1.0"];
  web [label="web-1.0",fillcolor=lightcoral,fontcolor=white];
  windows [label="windows-1.0"];

  app -> os;
  app -> windows [color="red",label="!",style="dashed"];
  app -> db;
  db -> os;
  os -> g1;
  g1 -> linux;
  g1 -> bsd;
  g1 -> windows;
  web -> os;
  web -> app;
  web -> db;
}