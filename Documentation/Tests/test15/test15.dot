digraph test15 {
  label="test15 \u2014 Negative USE !nolib? ( )";
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];

  app [label="app-1.0"];
  db [label="db-1.0"];
  lib [label="lib-1.0"];
  os [label="os-1.0"];
  web [label="web-1.0",fillcolor=lightcoral,fontcolor=white];

  app -> os;
  app -> lib [label="!nolib?"];
  app -> db;
  db -> os;
  lib -> os;
  web -> os;
  web -> app;
  web -> db;
}