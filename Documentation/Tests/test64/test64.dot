digraph test64 {
  label=<<B>test64</B> — USE-conditional churn>;
  labelloc=t; fontname=Helvetica; fontsize=12;
  graph [rankdir=LR];
  node  [fontname=Helvetica,fontsize=10,shape=box,style="rounded,filled",fillcolor=lightyellow];
  edge  [fontname=Helvetica,fontsize=9];

  app [label="app-1.0",fillcolor=lightcoral,fontcolor=white];
  openmp [label="openmp-1.0"];
  python [label="python-1.0"];
  hwloc [label="hwloc-1.0"];
  perl [label="perl-1.0"];
  ninja [label="ninja-1.0"];
  cmake [label="cmake-1.0"];
  g1 [label="||",shape=diamond,fillcolor=orange,fontcolor=white,fontsize=11,width=0.5,height=0.5];
  gpg [label="gpg-1.0"];
  gnupg [label="gnupg-1.0"];

  app -> openmp;
  openmp -> python [style=dashed,label="gdb-plugin?"];
  openmp -> hwloc [style=dashed,label="hwloc?"];
  openmp -> perl [style=dotted,label="BDEPEND"];
  openmp -> ninja [style=dotted,label="BDEPEND"];
  openmp -> cmake [style=dotted,label="BDEPEND"];
  openmp -> g1 [style=dashed,label="verify-sig?"];
  g1 -> gpg;
  g1 -> gnupg;
  python -> openmp [color=red,style=bold,label="C+R",fontcolor=red];
}